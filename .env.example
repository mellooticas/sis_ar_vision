# =============================================================================
# Clearix AR & Vision — Variaveis de ambiente
# =============================================================================
# Copie para .env.local e preencha os valores reais.
# =============================================================================

# --- SUPABASE (publicas — browser) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- SSO Gateway ---
NEXT_PUBLIC_SIS_GATEWAY_URL=https://clearixhub.netlify.app

# --- SSO Exchange Secret (server-side only — deve ser igual ao Hub) ---
SSO_EXCHANGE_SHARED_SECRET=

# --- Site URL (Netlify deploy URL) ---
NEXT_PUBLIC_SITE_URL=https://clearixarvision.netlify.app

# --- App ---
NEXT_PUBLIC_APP_NAME=Clearix AR & Vision

# --- Handoff para Clearix Vendas (opcional) ---
NEXT_PUBLIC_CLEARIX_VENDAS_URL=https://clearixvendas.netlify.app
